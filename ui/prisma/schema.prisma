generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Queue {
  id         Int     @id @default(autoincrement())
  gpu_ids    String  @unique
  is_running Boolean @default(false)

  @@index([gpu_ids])
}

model Job {
  id              String   @id @default(uuid())
  name            String   @unique
  gpu_ids         String
  job_config      String // JSON string
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  status          String   @default("stopped")
  stop            Boolean  @default(false)
  return_to_queue Boolean  @default(false) // same as stop, but will be set to 'queued' when stopped
  step            Int      @default(0)
  info            String   @default("")
  speed_string    String   @default("")
  queue_position  Int      @default(0)
  pid             Int?
  job_type        String   @default("train") // 'train', 'caption'
  job_ref         String? // can be used for anything for special jobs, like dataset path for caption jobs

  @@index([status])
  @@index([gpu_ids])
  @@index([job_type])
  @@index([job_ref])

}

model SystemMetricSample {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  scope      String
  device_id  String
  metric     String
  value      Float
  unit       String   @default("")
  metadata   String   @default("{}")

  @@index([created_at])
  @@index([scope, device_id, metric, created_at])
}

model ModelArtifact {
  id          String   @id
  kind        String
  name        String
  path        String
  source      String
  job_id      String?
  step        Int?
  exists      Boolean  @default(false)
  size        Float?
  modified_at DateTime?
  metadata    String   @default("{}")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([kind])
  @@index([job_id])
  @@index([source])
  @@index([exists])
}

model EvaluationRun {
  id             String   @id @default(uuid())
  name           String
  status         String   @default("queued")
  job_ids        String   @default("[]")
  artifact_ids   String   @default("[]")
  reference_path String?
  metrics        String   @default("{}")
  error          String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  completed_at   DateTime?

  items EvaluationItem[]

  @@index([status])
  @@index([created_at])
}

model EvaluationItem {
  id             String   @id @default(uuid())
  run_id         String
  item_type      String
  item_id        String
  sample_path    String?
  reference_path String?
  metrics        String   @default("{}")
  error          String?
  status         String   @default("queued")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  run EvaluationRun @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id])
  @@index([status])
}

model AlertRule {
  id               String   @id
  name             String
  metric           String
  operator         String
  threshold        Float
  duration_seconds Int      @default(0)
  severity         String
  enabled          Boolean  @default(true)
  config           String   @default("{}")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([enabled])
}

model AlertEvent {
  id              String   @id @default(uuid())
  rule_id         String?
  title           String
  message         String
  severity        String
  status          String   @default("active")
  resource_type   String
  resource_id     String
  fingerprint     String   @unique
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  acknowledged_at DateTime?
  snoozed_until   DateTime?
  resolved_at     DateTime?
  metadata        String   @default("{}")

  @@index([status])
  @@index([severity])
  @@index([resource_type, resource_id])
  @@index([rule_id])
}
